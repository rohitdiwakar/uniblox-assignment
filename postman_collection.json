{
  "info": {
    "name": "UniBlox E-Commerce API",
    "description": "Complete API collection for the UniBlox e-commerce assignment. Run requests in order for a full end-to-end flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "cartId",
      "value": "",
      "type": "string"
    },
    {
      "key": "discountCode",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "List all products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products",
            "description": "Returns all available products with their IDs and prices."
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Create cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('cartId', res.cartId);",
                  "console.log('Cart ID saved:', res.cartId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart",
            "description": "Creates a new cart. The returned cartId is saved as a collection variable automatically."
          }
        },
        {
          "name": "Add item — Wireless Headphones (x2)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/{{cartId}}/items",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"P001\",\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "name": "Add item — USB-C Hub (x1)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/{{cartId}}/items",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"P003\",\n  \"quantity\": 1\n}"
            }
          }
        },
        {
          "name": "Add same item again — merges quantity",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/{{cartId}}/items",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"P001\",\n  \"quantity\": 1\n}"
            },
            "description": "Adding P001 again should merge qty → 3 total for P001."
          }
        },
        {
          "name": "View cart",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/cart/{{cartId}}"
          }
        },
        {
          "name": "[Error] Add unknown product",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/{{cartId}}/items",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"P999\",\n  \"quantity\": 1\n}"
            },
            "description": "Expects 404 — product not found."
          }
        },
        {
          "name": "[Error] Invalid quantity (zero)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/{{cartId}}/items",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"P001\",\n  \"quantity\": 0\n}"
            },
            "description": "Expects 400 — quantity must be a positive integer."
          }
        }
      ]
    },
    {
      "name": "Checkout",
      "item": [
        {
          "name": "Checkout — no discount",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.earnedDiscountCode) {",
                  "  pm.collectionVariables.set('discountCode', res.earnedDiscountCode);",
                  "  console.log('Earned discount code saved:', res.earnedDiscountCode);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartId\": \"{{cartId}}\"\n}"
            },
            "description": "Places the order. If this is the Nth order, earnedDiscountCode is returned and saved automatically."
          }
        },
        {
          "name": "Checkout — with discount code",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartId\": \"{{cartId}}\",\n  \"discountCode\": \"{{discountCode}}\"\n}"
            },
            "description": "Uses the discount code earned from a previous Nth order. Create a new cart and add items first."
          }
        },
        {
          "name": "[Error] Checkout — empty cart",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartId\": \"{{cartId}}\"\n}"
            },
            "description": "After a successful checkout the cart is cleared. Re-using the same cartId expects 404."
          }
        },
        {
          "name": "[Error] Checkout — invalid discount code",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartId\": \"{{cartId}}\",\n  \"discountCode\": \"FAKECODE\"\n}"
            },
            "description": "Expects 404 — discount code not found."
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/stats",
            "description": "Returns totalOrders, totalItemsPurchased, totalRevenue, totalDiscountGiven, and discount code breakdown."
          }
        },
        {
          "name": "Generate discount code (if condition met)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/discount",
            "description": "Succeeds only when totalOrders is a non-zero multiple of NTH_ORDER (default: 5). Otherwise returns 400."
          }
        },
        {
          "name": "[Error] Generate discount code — condition not met",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/discount",
            "description": "If order count is not at a multiple of NTH_ORDER, expects 400 — condition not satisfied."
          }
        }
      ]
    }
  ]
}
